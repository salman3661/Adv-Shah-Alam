# ════════════════════════════════════════════════════════════════
# Admin Panel — Required Environment Variables
# Copy this file to .env.local and fill in the values.
# ALL of these must also be added to your Vercel project settings.
# ════════════════════════════════════════════════════════════════

# ── Admin Auth ──────────────────────────────────────────────────
# A long, random secret key used to sign admin session tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=your-long-random-secret-here

# The HMAC-SHA256 hash of your admin password (NOT the plain password).
# To generate this hash, run in Node.js:
#   const {createHmac} = require('crypto');
#   console.log(createHmac('sha256', 'YOUR_ADMIN_SECRET').update('YOUR_PASSWORD').digest('hex'));
ADMIN_PASSWORD_HASH=your-hashed-password-here

# ── GitHub Content Persistence ──────────────────────────────────
# A GitHub Personal Access Token with "repo" (read/write) scope.
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GitHub username
GITHUB_OWNER=salman3661

# Your GitHub repository name
GITHUB_REPO=Adv-Shah-Alam

# Branch to commit changes to (default: main)
GITHUB_BRANCH=main

# ── Vercel Deploy Hook ──────────────────────────────────────────
# A Vercel Deploy Hook URL that triggers a redeploy when POSTed to.
# Create at: https://vercel.com/your-project/settings/git → Deploy Hooks
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/prj_xxxxx/xxxx

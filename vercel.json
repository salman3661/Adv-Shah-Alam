{
  "redirects": [
    { "source": "/criminal-lawyer-uttara",         "destination": "/services/criminal-lawyer",     "permanent": true },
    { "source": "/divorce-lawyer-uttara",           "destination": "/services/divorce-lawyer",      "permanent": true },
    { "source": "/land-property-lawyer-uttara",     "destination": "/services/land-lawyer",         "permanent": true },
    { "source": "/bail-lawyer-dhaka",               "destination": "/services/bail-lawyer",         "permanent": true },
    { "source": "/supreme-court-lawyer-bangladesh", "destination": "/services/supreme-court-lawyer","permanent": true },
    { "source": "/tax-vat-lawyer-dhaka",            "destination": "/services/tax-lawyer",          "permanent": true },

    { "source": "/bn/blog/",               "destination": "/bn/blog",               "permanent": true },
    { "source": "/blog/",                  "destination": "/blog",                  "permanent": true },
    { "source": "/education/",             "destination": "/education",             "permanent": true },
    { "source": "/services/:slug/",        "destination": "/services/:slug",        "permanent": true },
    { "source": "/advocate-md-shah-alam/", "destination": "/advocate-md-shah-alam", "permanent": true },

    { "source": "/blog/divorce-process-bangladesh-complete-guide", "destination": "/blog/divorce-procedure-bangladesh", "permanent": true },
    { "source": "/blog/how-to-file-divorce-petition-bangladesh",   "destination": "/blog/divorce-procedure-bangladesh", "permanent": true },
    { "source": "/blog/divorce-process-bangladesh-2026",           "destination": "/blog/divorce-procedure-bangladesh", "permanent": true },
    { "source": "/blog/how-to-file-divorce-bangladesh",            "destination": "/blog/divorce-procedure-bangladesh", "permanent": true },
    { "source": "/blog/how-to-get-bail-bangladesh-2026",           "destination": "/blog/bail-process-bangladesh",      "permanent": true },
    { "source": "/blog/bail-process-bangladesh-2026",              "destination": "/blog/bail-process-bangladesh",      "permanent": true },
    { "source": "/blog/anticipatory-bail-high-court-bangladesh",   "destination": "/blog/anticipatory-bail-bangladesh", "permanent": true },

    { "source": "/blog/cheque-dishonour-case-bangladesh",          "destination": "/blog/138-ni-act-bangladesh-cheque-case-guide",   "permanent": true },
    { "source": "/blog/cheque-dishonour-bangladesh-section-138",   "destination": "/blog/138-ni-act-bangladesh-cheque-case-guide",   "permanent": true },
    { "source": "/blog/cheque-dishonour-case-law-bangladesh",      "destination": "/blog/138-ni-act-bangladesh-cheque-case-guide",   "permanent": true },

    { "source": "/blog/writ-petition-high-court-guide-bangladesh", "destination": "/blog/supreme-court-writ-petition-bangladesh", "permanent": true },
    { "source": "/blog/writ-petition-bangladesh-high-court",       "destination": "/blog/writ-petition-high-court-bangladesh",    "permanent": true },

    { "source": "/blog/child-custody-2026-bangladesh",             "destination": "/blog/child-custody-law-bangladesh",          "permanent": true },
    { "source": "/blog/child-custody-bangladesh-muslim-law",       "destination": "/blog/child-custody-law-bangladesh",          "permanent": true },

    { "source": "/blog/land-dispute-legal-remedies-bangladesh",    "destination": "/blog/land-dispute-case-bangladesh",          "permanent": true },

    { "source": "/blog/digital-security-act-rights-defences-bangladesh", "destination": "/blog/digital-security-act-bangladesh-legal-rights", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/:path*",   "destination": "/api/:path*" },
    { "source": "/admin/:path*", "destination": "/index.html" },
    { "source": "/admin",        "destination": "/index.html" },
    { "source": "/(.*)",         "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control",          "value": "no-store" }
      ]
    },
    {
      "source": "/((?!api).*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(sitemap.xml|robots.txt)",
      "headers": [
        { "key": "Cache-Control",  "value": "public, max-age=86400" },
        { "key": "X-Robots-Tag",   "value": "noindex" }
      ]
    }
  ]
}